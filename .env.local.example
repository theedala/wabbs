# Gmail SMTP for the contact form + newsletter.
# SMTP_PASS must be a Gmail "App Password" (16 chars), NOT your account password.
# Create one at: https://myaccount.google.com/apppasswords  (requires 2FA on)
#
# Copy this file to .env.local and fill in the values. NEVER put the real
# password in this .example file — it is committed to git.
SMTP_USER=alexandrawabbs@gmail.com
SMTP_PASS=your-16-char-app-password
# Where website enquiries are delivered (defaults to SMTP_USER if omitted).
CONTACT_TO=alexandrawabbs@gmail.com
